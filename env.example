# Database Configuration
POSTGRES_DB=medusa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure-postgres-password
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:secure-postgres-password@postgres:5432/medusa

# EmailEngine Database (separate database on same PostgreSQL instance)
EMAILENGINE_DB=emailengine
EMAILENGINE_DB_USER=postgres
EMAILENGINE_DB_PASSWORD=secure-postgres-password

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# MeiliSearch Configuration
MEILISEARCH_API_KEY=your-meilisearch-master-key
MEILISEARCH_ENV=production
MEILISEARCH_PORT=7700

# Medusa Configuration
MEDUSA_PORT=9000
NODE_ENV=production
MEDUSA_ADMIN_DISABLE=true

# Security - CHANGE THESE VALUES
JWT_SECRET=change-this-to-a-random-secure-key-32-characters
COOKIE_SECRET=change-this-to-a-random-secure-key-32-characters

# CORS Configuration
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:7001
AUTH_CORS=http://localhost:9000

# EmailEngine Configuration
EMAILENGINE_PORT=3333
EMAILENGINE_ADMIN_USER=admin
EMAILENGINE_ADMIN_PASS=change-this-to-secure-password
EMAILENGINE_SECRET=change-this-to-random-secret-key
EMAILENGINE_WEBHOOK_KEY=change-this-webhook-key

# EmailEngine Service Configuration (for Medusa integration)
EMAILENGINE_API_URL=https://icfix.duckdns.org/email
EMAILENGINE_API_KEY=your-emailengine-api-key
EMAILENGINE_ACCOUNT_ID=your-emailengine-account-id

# Gmail OAuth Configuration (for EmailEngine)
GMAIL_CLIENT_ID=your-gmail-oauth-client-id
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REDIRECT_URI=https://icfix.duckdns.org/email/auth/oauth/callback

# File Storage (Cloudflare R2) - Optional
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_FILE_URL=https://your-bucket-domain.com
R2_PREFIX=

