#!/usr/bin/expect -f

set timeout 60
set server_ip "116.118.48.209"
set server_user "root"
set server_pass "46532@Nvc"

# Check what PostgreSQL containers exist and their environment
spawn ssh -o StrictHostKeyChecking=no ${server_user}@${server_ip} "docker ps --filter 'name=postgres' --format '{{.Names}}' && docker exec icfix-postgres env | grep POSTGRES"

expect {
    "password:" {
        send "${server_pass}\r"
        exp_continue
    }
    eof {
        catch wait result
    }
}
